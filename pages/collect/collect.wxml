<view class="container">
  <!-- 状态栏 - 左上角 -->
  <view class="status-bar">
    <text>{{streaming ? 'FPS:' + fps + ' | Saved:' + savedCount : 'Connecting...'}}</text>
  </view>

  <!-- 顶部控制栏 -->
  <view class="top-control">
    <view class="start-btn {{running ? 'running' : ''}}" bindtap="onStartStop">
      <text>{{running ? '停止' : '启动'}}</text>
    </view>
    <view class="speed-control">
      <text class="speed-label">速度</text>
      <slider class="speed-slider" min="1" max="10" value="{{speed}}" block-size="20" activeColor="#4CAF50" backgroundColor="#333" bindchange="onSpeedChange" />
      <text class="speed-value">{{speed}}</text>
    </view>
  </view>

  <!-- 图像区 - 居中 -->
  <view class="image-area">
    <image class="preview" src="{{imageData}}" mode="aspectFit" wx:if="{{imageData}}"></image>
    <text class="placeholder" wx:else>等待图像...</text>
  </view>

  <!-- 左侧控制 - 左转 -->
  <view class="control-left">
    <view class="ctrl-btn" bindtouchstart="onLeft" bindtouchend="onStop"></view>
  </view>

  <!-- 右侧控制 - 右转 -->
  <view class="control-right">
    <view class="ctrl-btn" bindtouchstart="onRight" bindtouchend="onStop"></view>
  </view>

</view>
