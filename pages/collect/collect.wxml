<view class="container">
  <!-- 状态栏 - 左上角 -->
  <view class="status-bar">
    <text>{{streaming ? '采集中 帧率' + fps : '连接中...'}}</text>
  </view>

  <!-- 图像区 - 居中 -->
  <view class="image-area">
    <image class="preview" src="{{imageData}}" mode="aspectFit" wx:if="{{imageData}}"></image>
    <text class="placeholder" wx:else>等待图像...</text>
  </view>

  <!-- 左侧控制 - 左转 -->
  <view class="control-left">
    <view class="ctrl-btn" bindtouchstart="onLeft" bindtouchend="onStop"></view>
  </view>

  <!-- 右侧控制 - 右转 -->
  <view class="control-right">
    <view class="ctrl-btn" bindtouchstart="onRight" bindtouchend="onStop"></view>
  </view>

</view>
