page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
  overflow: hidden;
}

.status-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 10rpx 16rpx;
  color: #4CAF50;
  font-size: 16rpx;
  font-weight: bold;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
  z-index: 10;
}

.image-area {
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview {
  width: 480rpx;
  border: none;
  border-radius: 0;
}

.placeholder {
  color: #666;
  font-size: 28rpx;
}

/* 左侧控制区 - 左转 */
.control-left {
  position: absolute;
  left: 40rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 右侧控制区 - 右转 */
.control-right {
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 控制按钮 - 半透明带粗箭头 */
.ctrl-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ctrl-btn:active {
  background: rgba(255, 255, 255, 0.6);
}

/* 左转箭头 */
.control-left .ctrl-btn::before {
  content: '';
  width: 0;
  height: 0;
  border-top: 30rpx solid transparent;
  border-bottom: 30rpx solid transparent;
  border-right: 50rpx solid #fff;
}

/* 右转箭头 */
.control-right .ctrl-btn::before {
  content: '';
  width: 0;
  height: 0;
  border-top: 30rpx solid transparent;
  border-bottom: 30rpx solid transparent;
  border-left: 50rpx solid #fff;
}
