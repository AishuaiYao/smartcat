.container {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  background: #1a1a1a;
}

.control-left,
.control-right {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 40rpx;
  width: 160rpx;
}

.image-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  margin: 0 20rpx;
}

.preview {
  width: 100%;
  height: 100%;
  border: 4rpx solid #333;
  border-radius: 8rpx;
}

.placeholder {
  color: #666;
  font-size: 28rpx;
}

.ctrl-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  border: none;
}

.forward {
  background: #4CAF50;
}

.backward {
  background: #f44336;
}

.left {
  background: #2196F3;
}

.right {
  background: #FF9800;
}

.ctrl-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}
