page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
  overflow: hidden;
}

.status-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 10rpx 16rpx;
  color: #4CAF50;
  font-size: 16rpx;
  font-weight: bold;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
  z-index: 10;
}

.image-area {
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview {
  width: 480rpx;
  border: none;
  border-radius: 0;
}

.placeholder {
  color: #666;
  font-size: 28rpx;
}

.control-area {
  width: 100%;
  padding: 20rpx;
}

.control-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.ctrl-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  border: none;
}

.forward {
  background: #4CAF50;
}

.backward {
  background: #f44336;
}

.left {
  background: #2196F3;
}

.right {
  background: #FF9800;
}

.ctrl-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}
