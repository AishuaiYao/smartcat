.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  background: #1a1a1a;
}

.status-bar {
  width: 100%;
  padding: 20rpx;
  text-align: center;
  color: #4CAF50;
  font-size: 32rpx;
  font-weight: bold;
}

.image-area {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0;
}

.preview {
  width: 100%;
  max-width: 480rpx;
  border: 4rpx solid #333;
  border-radius: 8rpx;
}

.placeholder {
  color: #666;
  font-size: 28rpx;
}

.control-area {
  width: 100%;
  padding: 20rpx;
}

.control-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.ctrl-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  border: none;
}

.forward {
  background: #4CAF50;
}

.backward {
  background: #f44336;
}

.left {
  background: #2196F3;
}

.right {
  background: #FF9800;
}

.ctrl-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}
