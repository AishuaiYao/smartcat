<view class="page">
  <!-- 顶部区域 -->
  <view class="top-bar">
    <text class="avatar">🐱</text>
    <text class="add-btn" bindtap="onFabTap">➕</text>
  </view>

  <!-- 标题行 -->
  <view class="title-row">
    <text class="title-left">常用</text>
    <text class="title-right" bindtap="onSettingsTap">⚙️ 设置</text>
  </view>

  <!-- 设备列表 -->
  <scroll-view class="device-list" scroll-y>
    <view class="card-grid">
      <view class="device-card" wx:for="{{devices}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">
        <text class="card-icon">{{item.icon}}</text>
        <text class="card-name">{{item.name}}</text>
        <text class="card-status">{{item.status}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部导航 -->
  <view class="bottom-bar">
    <view class="nav-item" bindtap="onTabTap" data-tab="home">
      <text>🏠</text>
      <text>首页</text>
    </view>
    <view class="nav-item" bindtap="onTabTap" data-tab="smart">
      <text>🔔</text>
      <text>智能</text>
    </view>
    <view class="nav-item" bindtap="onTabTap" data-tab="assistant">
      <text>💬</text>
      <text>助手</text>
    </view>
    <view class="nav-item" bindtap="onTabTap" data-tab="my">
      <text>👤</text>
      <text>我的</text>
    </view>
  </view>

  <!-- 雷达弹窗 -->
  <view class="radar-modal {{showRadar ? 'show' : ''}}" bindtap="onRadarClose">
    <view class="radar-box" catchtap="">
      <view class="radar-circle"></view>
      <view class="radar-circle c2"></view>
      <view class="radar-circle c3"></view>
      <view class="radar-sweep"></view>
      <view class="radar-icon">📡</view>
      <text class="radar-text">{{radarStatus}}</text>
      <view class="ok-btn {{showConfirm ? 'visible' : ''}}" bindtap="onConfirm">✅ 确认</view>
    </view>
  </view>
</view>
