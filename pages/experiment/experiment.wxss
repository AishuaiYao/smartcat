page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
  overflow: hidden;
}

.status-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 6rpx 10rpx;
  color: #2196F3;
  font-size: 12rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 4rpx;
  z-index: 10;
  font-family: monospace;
}

.status-bar-right {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 10rpx;
  color: #2196F3;
  font-size: 12rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 4rpx;
  z-index: 10;
  font-family: monospace;
}

.top-control {
  position: absolute;
  top: 1rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 10;
}

.start-btn {
  padding: 2rpx 20rpx;
  background: #2196F3;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 24rpx;
}

.start-btn.running {
  background: #ff4d4f;
}

.speed-control {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 2rpx 15rpx;
  border-radius: 24rpx;
}

.speed-label {
  color: #fff;
  font-size: 20rpx;
}

.speed-btn {
  width: 40rpx;
  height: 40rpx;
  background: #2196F3;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 40rpx;
}

.speed-btn:active {
  background: #1976D2;
}

.speed-value {
  color: #2196F3;
  font-size: 20rpx;
  font-weight: bold;
  min-width: 30rpx;
  text-align: center;
}

.image-area {
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview {
  width: 480rpx;
  border: none;
  border-radius: 0;
}

.placeholder {
  color: #666;
  font-size: 28rpx;
}
