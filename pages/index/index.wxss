.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.status-bar {
  width: 100%;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.status-bar.connected {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-bar.disconnected {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.btn {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}

.btn-connect {
  background-color: #07c160;
  color: white;
}

.btn-disconnect {
  background-color: #ff4d4f;
  color: white;
}

.btn-capture {
  background-color: #1890ff;
  color: white;
}

.btn-album {
  background-color: #722ed1;
  color: white;
}

.preview-section {
  width: 100%;
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: white;
  border-radius: 12rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.preview-image {
  width: 100%;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

.stats-bar {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  margin-top: 30rpx;
  background-color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  color: #1890ff;
  font-size: 32rpx;
}

.tips {
  width: 100%;
  margin-top: 40rpx;
  padding: 24rpx;
  background-color: #fffbe6;
  border-radius: 12rpx;
  border: 1rpx solid #ffe58f;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #d48806;
  margin-bottom: 12rpx;
  display: block;
}

.tips text {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.progress-bar {
  width: 400rpx;
  height: 16rpx;
  background-color: #e0e0e0;
  border-radius: 8rpx;
  margin: 10rpx 0 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #1890ff;
  border-radius: 8rpx;
  transition: width 0.2s;
}

.log-panel {
  width: 100%;
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #1a1a2e;
  border-radius: 12rpx;
}

.log-title {
  font-size: 24rpx;
  color: #00ff88;
  display: block;
  margin-bottom: 12rpx;
  font-weight: bold;
}

.log-scroll {
  height: 500rpx;
}

.log-line {
  display: block;
  font-size: 20rpx;
  color: #e0e0e0;
  margin-top: 6rpx;
  font-family: monospace;
}
