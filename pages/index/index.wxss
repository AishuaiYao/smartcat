.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 100vh;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 80rpx;
}

.search-btn {
  width: 500rpx;
  height: 90rpx;
  line-height: 90rpx;
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  border-radius: 45rpx;
  margin-bottom: 40rpx;
}

.search-btn:active {
  background-color: #06ad56;
}

.status {
  color: #888;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.robot-list {
  width: 100%;
  margin-top: 40rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.robot-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  background-color: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.robot-name {
  font-size: 30rpx;
  color: #333;
}

.robot-status {
  font-size: 26rpx;
  color: #07c160;
}
