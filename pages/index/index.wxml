<view class="container">
  <!-- 连接状态 -->
  <view class="status-bar {{connected ? 'connected' : 'disconnected'}}">
    <text>{{connecting ? '连接中...' : (connected ? '已连接 ' + deviceName : '未连接')}}</text>
  </view>

  <!-- 测试按钮 -->
  <button class="btn btn-capture"
          bindtap="captureImage"
          disabled="{{!connected || capturing}}">
    {{capturing ? '采集中 ' + progress + '%' : '测试'}}
  </button>

  <!-- 数据采集按钮 -->
  <button class="btn btn-collect"
          bindtap="goToCollect"
          disabled="{{!connected}}">
    数据采集
  </button>

  <!-- 进度条 -->
  <view class="progress-bar" wx:if="{{capturing}}">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>

  <!-- 当前拍摄预览 -->
  <view class="preview-section" wx:if="{{imageData}}">
    <text class="section-title">当前拍摄</text>
    <image class="preview-image" src="{{imageData}}" mode="widthFix"></image>
  </view>

  <!-- 本地图片统计 -->
  <view class="stats-bar" bindtap="goToAlbum">
    <text>本地已保存 {{imageCount}} 张图片</text>
    <text class="arrow">→</text>
  </view>

  <!-- 跳转相册 -->
  <button class="btn btn-album" bindtap="goToAlbum">
    打开相册
  </button>

  <!-- 使用提示 -->
  <view class="tips">
    <text class="tips-title">使用说明：</text>
    <text>1. 点击"拍照"采集图像</text>
    <text>2. 图片自动保存到本地</text>
    <text>3. 切回家里WiFi后去相册上传</text>
  </view>

  <!-- 调试日志 -->
  <view class="log-panel">
    <text class="log-title">调试日志 ({{logMsgs.length}})</text>
    <scroll-view class="log-scroll" scroll-y scroll-into-view="log-top">
      <text id="log-top"></text>
      <text class="log-line" wx:for="{{logMsgs}}" wx:key="index">{{item}}</text>
    </scroll-view>
  </view>
</view>
